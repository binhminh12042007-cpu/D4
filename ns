<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NSBIR - Nostalgic One | DNA.Me</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        .nsbir-page { width: 100%; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }
        .nsbir-page .container { justify-content: center; padding-top: 0; min-height: auto; align-items: center; }
        .nsbir-content { text-align: left; width: 100%; max-width: 800px; animation: fadeInUp 0.6s ease forwards; margin-top: 100px; margin-bottom: 120px; scroll-margin-top: 100px; padding-bottom: 20px; }
        .nsbir-content:target { scroll-margin-top: 100px; }
        .nsbir-header { text-align: center; margin-bottom: 40px; padding: 40px 30px; background: linear-gradient(135deg, rgba(121, 85, 72, 0.2), rgba(93, 64, 55, 0.2)); border-radius: 24px; border: 1px solid rgba(255, 255, 255, 0.4); backdrop-filter: blur(10px); }
        .nsbir-header .type-code { display: inline-block; font-size: 3rem; font-weight: 900; letter-spacing: 12px; color: #8D6E63; text-shadow: 0 2px 10px rgba(121, 85, 72, 0.3); margin-bottom: 12px; }
        .nsbir-header .type-name { font-size: 1.8rem; font-weight: 700; color: #2D3748; margin-bottom: 16px; }
        .nsbir-header .type-tagline { font-size: 1.1rem; color: #4A5568; font-style: italic; }
        .symbol-card { background: rgba(255, 255, 255, 0.9); border-radius: 20px; padding: 32px 36px; margin-bottom: 28px; box-shadow: 0 8px 30px rgba(141, 110, 99, 0.12); border: 1px solid rgba(255, 255, 255, 0.6); position: relative; overflow: hidden; }
        .symbol-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 5px; background: linear-gradient(180deg, #8D6E63, #A1887F, #BCAAA4); }
        .symbol-card h2 { margin-top: 0; margin-bottom: 24px; font-size: 1.4rem; font-weight: 700; color: #8D6E63; display: flex; align-items: center; gap: 12px; }
        .symbol-card h2 i { font-size: 1.2rem; }
        .symbol-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; }
        .symbol-item { display: flex; align-items: flex-start; gap: 14px; padding: 16px; background: rgba(141, 110, 99, 0.06); border-radius: 14px; transition: all 0.3s ease; }
        .symbol-item:hover { background: rgba(141, 110, 99, 0.12); transform: translateX(4px); }
        .symbol-letter { flex-shrink: 0; width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #8D6E63, #A1887F); color: white; font-size: 1.3rem; font-weight: 800; border-radius: 10px; box-shadow: 0 4px 12px rgba(141, 110, 99, 0.3); }
        .symbol-text { flex: 1; }
        .symbol-text .trait { font-weight: 700; color: #2D3748; font-size: 1rem; margin-bottom: 4px; }
        .symbol-text .description { font-size: 0.9rem; color: #4A5568; line-height: 1.5; }
        .nsbir-section { background: rgba(255, 255, 255, 0.88); border-radius: 20px; padding: 32px 36px; margin-bottom: 28px; box-shadow: 0 6px 24px rgba(0, 0, 0, 0.06); border: 1px solid rgba(255, 255, 255, 0.6); backdrop-filter: blur(10px); transition: transform 0.3s ease, box-shadow 0.3s ease; position: relative; overflow: hidden; }
        .nsbir-section:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0, 0, 0, 0.1); }
        .nsbir-section::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: linear-gradient(180deg, #8D6E63 0%, #A1887F 50%, #BCAAA4 100%); border-radius: 20px 0 0 20px; }
        .nsbir-section h2 { margin-top: 0; margin-bottom: 22px; font-size: 1.35rem; font-weight: 700; color: #2D3748; display: flex; align-items: center; gap: 12px; position: relative; }
        .nsbir-section h2::after { content: ''; flex: 1; height: 2px; background: linear-gradient(90deg, rgba(141, 110, 99, 0.3), transparent); margin-left: 16px; border-radius: 2px; }
        .nsbir-section h2 .section-icon { font-size: 1.2rem; color: #8D6E63; text-shadow: 0 2px 8px rgba(141, 110, 99, 0.3); }
        .nsbir-section p { margin-bottom: 16px; line-height: 1.75; color: #4A5568; font-size: 0.98rem; }
        .nsbir-section p:last-child { margin-bottom: 0; }
        .nsbir-section ul { list-style: none; padding: 0; margin: 16px 0; }
        .nsbir-section ul li { padding: 12px 0 12px 34px; position: relative; color: #4A5568; font-size: 0.97rem; line-height: 1.6; border-bottom: 1px solid rgba(0, 0, 0, 0.04); }
        .nsbir-section ul li:last-child { border-bottom: none; }
        .nsbir-section ul li::before { content: '✦'; position: absolute; left: 0; top: 12px; color: #8D6E63; font-size: 0.85rem; }
        .strengths-challenges { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 16px; }
        .strengths-box, .challenges-box { padding: 20px; border-radius: 16px; }
        .strengths-box { background: linear-gradient(135deg, rgba(188, 170, 164, 0.2), rgba(161, 136, 127, 0.2)); border: 1px solid rgba(141, 110, 99, 0.2); }
        .challenges-box { background: linear-gradient(135deg, rgba(255, 182, 193, 0.15), rgba(255, 182, 193, 0.25)); border: 1px solid rgba(255, 182, 193, 0.3); }
        .strengths-box h3, .challenges-box h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
        .strengths-box h3 { color: #8D6E63; }
        .challenges-box h3 { color: #C75B5B; }
        .strengths-box ul li::before { content: '✓'; color: #8D6E63; }
        .challenges-box ul li::before { content: '!'; color: #C75B5B; font-weight: bold; }
        .back-section { text-align: center; margin-top: 40px; margin-bottom: 20px; }
        .back-btn { display: inline-flex; align-items: center; gap: 10px; padding: 14px 32px; background: linear-gradient(135deg, #8D6E63, #A1887F); color: white; text-decoration: none; border: none; border-radius: 14px; font-weight: 600; font-size: 1rem; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(141, 110, 99, 0.35); cursor: pointer; }
        .back-btn:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 8px 25px rgba(141, 110, 99, 0.45); background: linear-gradient(135deg, #795548, #8D6E63); }
        .back-btn i { font-size: 0.9rem; }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        @media (max-width: 768px) {
            .nsbir-header { padding: 30px 20px; }
            .nsbir-header .type-code { font-size: 2.2rem; letter-spacing: 8px; }
            .nsbir-header .type-name { font-size: 1.4rem; }
            .symbol-card, .nsbir-section { padding: 24px 20px; }
            .symbol-grid { grid-template-columns: 1fr; }
            .strengths-challenges { grid-template-columns: 1fr; }
            .nsbir-section h2 { font-size: 1.2rem; flex-direction: column; align-items: flex-start; gap: 8px; }
            .nsbir-section h2::after { display: none; }
        }
    </style>
</head>
